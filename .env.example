# Database (required)
DB_HOST=
DB_PORT=
DB_NAME=
DB_USER=
DB_PASSWORD=

# Admin dashboard API password
ADMIN_PASSWORD=

# Textify Africa SMS (https://portal.textify.africa)
TEXTIFY_API_KEY= 
TEXTIFY_SENDER_NAME=

# Optional: POST /api/webhooks/textify — header x-textify-secret or ?secret=
